# Copy this file to .env and fill in your values
DB_HOST=your_host_from_clever_cloud
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name
API_KEY=testkey123
PORT=3000

# Optional OHR lookup configuration (defaults are already set in server.js)
OHR_SHEET_ID=1KlfU6Juc2vlErxgRoDEGLq6trNIyjqUNMjmr3q7K6vM
OHR_SHEET_GID=0
# OHR_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0

# Optional webhook to write registration timestamp externally (e.g. Apps Script)
# OHR_TIMESTAMP_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec

# Optional: only if your server cannot validate Google TLS certificates
# ALLOW_INSECURE_TLS=true
